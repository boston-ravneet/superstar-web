{
  "expo": {
    "name": "Superstar",
    "slug": "superstar-mobile",
    "version": "1.0.1",
    "description": "Build and publish your personal stage at getsuperstar.info — bio, photos, showreel, and social links in minutes.",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "scheme": "superstar",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "info.getsuperstar.mobile",
      "buildNumber": "1",
      "usesAppleSignIn": true,
      "infoPlist": {
        "CFBundleDisplayName": "Superstar",
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "Allow Superstar to access your photos so you can add a headshot and portfolio images to your public page."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "info.getsuperstar.mobile",
      "permissions": []
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Superstar to access your photos for profile customization."
        }
      ],
      "expo-asset",
      "expo-font",
      "expo-web-browser",
      "expo-secure-store",
      "expo-apple-authentication"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2806f64e-1dc3-4187-b6f9-4efb32d900e2"
      }
    },
    "owner": "boston_ravneet"
  }
}
