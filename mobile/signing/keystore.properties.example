# Copy to mobile/android/keystore.properties (do not commit).
# Place your upload keystore .jks in mobile/signing/ (also do not commit).
#
# Play Console expects upload key SHA-1:
#   67:E8:15:11:91:27:C4:46:60:9E:7F:08:3F:6D:75:01:AA:7B:02:18
#
# Download from EAS: cd mobile && eas credentials -p android
#   → production → Keystore → Download

storeFile=../signing/upload-keystore.jks
storePassword=YOUR_STORE_PASSWORD
keyAlias=YOUR_KEY_ALIAS
keyPassword=YOUR_KEY_PASSWORD
