{
  "name": "superstar-mobile",
  "version": "1.0.1",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "build:ios": "eas build --platform ios --profile production",
    "build:ios:preview": "eas build --platform ios --profile preview",
    "build:android": "eas build --platform android --profile production",
    "build:android:local": "npm run prebuild:android && eas build --platform android --profile production --local",
    "prebuild:android": "EAS_BUILD_PLATFORM=android npx expo prebuild --platform android --clean",
    "build:android:preview": "eas build --platform android --profile preview",
    "submit:ios": "eas submit --platform ios --profile production --latest",
    "submit:android": "eas submit --platform android --profile production --latest"
  },
  "dependencies": {
    "@react-native-google-signin/google-signin": "^16.1.2",
    "expo": "^54.0.0",
    "expo-apple-authentication": "~8.0.8",
    "expo-asset": "~12.0.13",
    "expo-auth-session": "~7.0.11",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-font": "~14.0.12",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-linking": "~8.0.12",
    "expo-router": "~6.0.24",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.11",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-google-mobile-ads": "^16.4.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-webview": "13.15.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "~54.0.10",
    "typescript": "^5.3.3"
  },
  "expo": {
    "doctor": {
      "appConfigFieldsNotSyncedCheck": {
        "enabled": false
      },
      "reactNativeDirectoryCheck": {
        "enabled": false
      }
    }
  }
}
