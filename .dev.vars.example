# Copy ONCE for local dev:
#   npm run dev:init
# Then add GEMINI_API_KEY below. Never run `cp .dev.vars.example .dev.vars` again — it wipes secrets.
NEXTJS_ENV=development
R2_PUBLIC_BASE_URL=http://localhost:3000/media
UPLOAD_SIGNING_SECRET=local-dev-upload-secret
SESSION_SIGNING_SECRET=local-dev-session-secret
ALLOW_DEV_AUTH=true
GOOGLE_CLIENT_ID=
GEMINI_API_KEY=
